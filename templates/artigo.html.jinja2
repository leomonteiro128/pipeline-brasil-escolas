<!-- ═══ SCRIPTS ═══ -->
<script defer src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script defer src="/assets/js/config.js"></script>
<script defer src="/assets/js/supabase-client.js"></script>
<script defer src="/assets/js/utils.js"></script>
<script defer src="/assets/js/search.js"></script>

<!-- Script inline: AdSense in-article após 3° parágrafo -->
<script>
document.addEventListener('DOMContentLoaded', function () {
  const body = document.getElementById('artigo-body');
  if (!body) return;
  const paragrafos = body.querySelectorAll('p');
  if (paragrafos.length >= 3) {
    const adEl = document.createElement('div');
    adEl.className = 'adsense-block adsense-in-article';
    adEl.setAttribute('aria-label', 'Publicidade');
    adEl.innerHTML = `
      <ins class="adsbygoogle"
           style="display:block; text-align:center;"
           data-ad-layout="in-article"
           data-ad-format="fluid"
           data-ad-client="ca-pub-6391161522269960"
           data-ad-slot="auto"></ins>
      <script>(adsbygoogle = window.adsbygoogle || []).push({});<\/script>`;
    paragrafos[2].insertAdjacentElement('afterend', adEl);
  }
});
</script>

<!-- Script inline: Artigos relacionados do Supabase -->
<script>
(function () {
  const SLUG_ATUAL = '{{ artigo.slug }}';
  const CATEGORIA = '{{ artigo.categoria }}';
  const grid = document.getElementById('relacionadosGrid');

  function formatarData(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    return d.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
  }

  function renderCard(art) {
    return `
      <article class="artigo-card" role="listitem" itemscope itemtype="https://schema.org/Article">
        <a href="/artigos/${art.slug}/" class="artigo-card-link" aria-label="${art.titulo}">
          <div class="artigo-card-img-wrap">
            <img src="${art.imagem_url || '/assets/img/og-image.png'}"
                 alt="${art.imagem_alt || art.titulo}"
                 class="artigo-card-img"
                 width="400" height="225"
                 loading="lazy" decoding="async"
                 itemprop="image">
          </div>
          <div class="artigo-card-body">
            <span class="artigo-badge artigo-badge-sm">${art.categoria}</span>
            <h3 class="artigo-card-titulo" itemprop="headline">${art.titulo}</h3>
            <p class="artigo-card-excerpt">${art.excerpt || ''}</p>
            <div class="artigo-card-meta">
              <time datetime="${art.publicado_em}" itemprop="datePublished">${formatarData(art.publicado_em)}</time>
              ${art.tempo_leitura ? `<span>· ${art.tempo_leitura} min</span>` : ''}
            </div>
          </div>
        </a>
      </article>`;
  }

  function renderVazio() {
    grid.innerHTML = `
      <div class="artigos-vazio" style="grid-column:1/-1;text-align:center;padding:40px;color:var(--text-muted)">
        <p>Nenhum artigo relacionado encontrado.</p>
        <a href="/artigos/" class="btn btn-secondary" style="margin-top:16px">Ver todos os artigos</a>
      </div>`;
  }

  async function carregarRelacionados() {
    if (typeof buscarArtigos !== 'function') {
      // fallback: tenta via supabase global
      setTimeout(carregarRelacionados, 500);
      return;
    }
    try {
      const artigos = await buscarArtigos({ categoria: CATEGORIA, limit: 4, excluir_slug: SLUG_ATUAL });
      const lista = (artigos || []).filter(a => a.slug !== SLUG_ATUAL).slice(0, 3);
      if (!lista.length) { renderVazio(); return; }
      grid.innerHTML = lista.map(renderCard).join('');
    } catch (e) {
      console.warn('Erro ao carregar artigos relacionados:', e);
      renderVazio();
    }
  }

  window.addEventListener('load', carregarRelacionados);
})();
</script>

</body>
</html>
