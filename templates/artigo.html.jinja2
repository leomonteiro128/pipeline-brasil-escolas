<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ artigo.meta_title or artigo.titulo }} | Brasil Escolas</title>
  <meta name="description" content="{{ artigo.meta_description }}">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://brasilescolas.com.br/artigos/{{ artigo.slug }}/">

  <!-- Favicons -->
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/img/favicon-32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/img/favicon-16.png">
  <link rel="icon" type="image/png" href="/assets/img/favicon.png">
  <link rel="apple-touch-icon" href="/assets/img/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="theme-color" content="#003F7F">

  <!-- Open Graph -->
  <meta property="og:type" content="article">
  <meta property="og:url" content="https://brasilescolas.com.br/artigos/{{ artigo.slug }}/">
  <meta property="og:title" content="{{ artigo.meta_title or artigo.titulo }}">
  <meta property="og:description" content="{{ artigo.meta_description }}">
  <meta property="og:image" content="{{ artigo.imagem_url }}">
  <meta property="og:locale" content="pt_BR">
  <meta property="og:site_name" content="Brasil Escolas">
  <meta property="article:published_time" content="{{ artigo.publicado_em }}">
  <meta property="article:author" content="Leonardo Monteiro">
  <meta property="article:section" content="{{ artigo.categoria }}">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ artigo.meta_title or artigo.titulo }}">
  <meta name="twitter:description" content="{{ artigo.meta_description }}">
  <meta name="twitter:image" content="{{ artigo.imagem_url }}">

  <!-- Preload fontes -->
  <link rel="preload" href="/assets/fonts/Poppins-Bold.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/Inter-Regular.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="{{ artigo.imagem_url }}" as="image">

  <!-- CSS -->
  <link rel="stylesheet" href="/assets/css/main.css">
  <link rel="stylesheet" href="/assets/css/artigo.css">

  <!-- AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6391161522269960" crossorigin="anonymous"></script>

  <!-- Schema.org Article -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Article",
        "headline": "{{ artigo.titulo }}",
        "description": "{{ artigo.meta_description }}",
        "image": {
          "@type": "ImageObject",
          "url": "{{ artigo.imagem_url }}",
          "width": 800,
          "height": 450
        },
        "datePublished": "{{ artigo.publicado_em }}",
        "dateModified": "{{ artigo.atualizado_em or artigo.publicado_em }}",
        "author": {
          "@type": "Person",
          "name": "Leonardo Monteiro",
          "url": "https://brasilescolas.com.br/sobre/"
        },
        "publisher": {
          "@type": "Organization",
          "name": "Brasil Escolas",
          "url": "https://brasilescolas.com.br",
          "logo": {
            "@type": "ImageObject",
            "url": "https://brasilescolas.com.br/assets/img/logo.png",
            "width": 180,
            "height": 48
          }
        },
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": "https://brasilescolas.com.br/artigos/{{ artigo.slug }}/"
        },
        "articleSection": "{{ artigo.categoria }}",
        "inLanguage": "pt-BR"
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "Início", "item": "https://brasilescolas.com.br/"},
          {"@type": "ListItem", "position": 2, "name": "Artigos", "item": "https://brasilescolas.com.br/artigos/"},
          {"@type": "ListItem", "position": 3, "name": "{{ artigo.categoria }}", "item": "https://brasilescolas.com.br/artigos/?categoria={{ artigo.categoria|urlencode }}"},
          {"@type": "ListItem", "position": 4, "name": "{{ artigo.titulo[:60] }}", "item": "https://brasilescolas.com.br/artigos/{{ artigo.slug }}/"}
        ]
      }
    ]
  }
  </script>
</head>
<body>

<!-- Skip Link Acessibilidade -->
<a class="skip-link" href="#main">Ir para o conteúdo principal</a>

<!-- ═══ HEADER ═══ -->
<header class="site-header" role="banner">
  <div class="header-inner">
    <a href="/" class="header-logo" aria-label="Brasil Escolas — página inicial">
      <img src="/assets/img/logo.png" alt="Brasil Escolas" width="180" height="48">
    </a>

    <!-- Busca central desktop -->
    <div class="header-search" role="search" aria-label="Busca rápida no header">
      <input type="search" id="headerSearch" placeholder="Buscar escola, cidade, bairro…"
        aria-label="Buscar escola" autocomplete="off">
      <button class="header-search-btn" aria-label="Pesquisar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
      <div class="search-dropdown" id="headerSearchDropdown" style="display:none" role="listbox" aria-label="Sugestões de busca"></div>
    </div>

    <!-- Navegação desktop -->
    <nav class="main-nav" aria-label="Navegação principal">
      <a href="/">Início</a>
      <a href="/escolas/">Escolas</a>
      <a href="/inclusao/">Inclusão</a>
      <a href="/artigos/" aria-current="page" class="active">Artigos</a>
      <a href="/vagas-emprego-estagio/">Vagas</a>
      <a href="/cadastrar-escola/" class="btn-cadastrar">+ Cadastrar Escola</a>
    </nav>

    <!-- Botão hamburger mobile -->
    <button class="hamburger" id="hamburger" aria-label="Abrir menu" aria-expanded="false" aria-controls="mobileDrawer">
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
  </div>
</header>

<!-- Drawer mobile -->
<div class="mobile-drawer" id="mobileDrawer" role="dialog" aria-modal="true" aria-label="Menu de navegação">
  <button class="mobile-drawer-close" id="drawerClose" aria-label="Fechar menu">&#x2715;</button>
  <nav aria-label="Menu mobile">
    <a href="/">&#x1F3E0; Início</a>
    <a href="/escolas/">&#x1F3EB; Escolas</a>
    <a href="/inclusao/">&#x1F9E9; Inclusão</a>
    <a href="/artigos/" aria-current="page">&#x1F4F0; Artigos</a>
    <a href="/vagas-emprego-estagio/">&#x1F4BC; Vagas</a>
    <a href="/sobre/">&#x2139;&#xFE0F; Sobre</a>
    <a href="/contato/">&#x1F4E7; Contato</a>
    <a href="/cadastrar-escola/" class="btn-cadastrar-mobile">+ Cadastrar Escola</a>
  </nav>
</div>
<div class="mobile-overlay" id="mobileOverlay" aria-hidden="true"></div>

<!-- ═══ CONTEÚDO PRINCIPAL ═══ -->
<main id="main" tabindex="-1">

  <!-- Breadcrumb -->
  <nav class="breadcrumb-nav" aria-label="Caminho de navegação">
    <div class="container">
      <ol class="breadcrumb" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="/" itemprop="item"><span itemprop="name">Início</span></a>
          <meta itemprop="position" content="1">
        </li>
        <li aria-hidden="true">&#x203A;</li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="/artigos/" itemprop="item"><span itemprop="name">Artigos</span></a>
          <meta itemprop="position" content="2">
        </li>
        <li aria-hidden="true">&#x203A;</li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="/artigos/?categoria={{ artigo.categoria|urlencode }}" itemprop="item"><span itemprop="name">{{ artigo.categoria }}</span></a>
          <meta itemprop="position" content="3">
        </li>
        <li aria-hidden="true">&#x203A;</li>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span itemprop="name">{{ artigo.titulo[:40] }}{% if artigo.titulo|length > 40 %}…{% endif %}</span>
          <meta itemprop="position" content="4">
        </li>
      </ol>
    </div>
  </nav>

  <!-- Artigo -->
  <article class="artigo-container" itemscope itemtype="https://schema.org/Article">
    <div class="container artigo-wrapper">

      <!-- Badge categoria -->
      <div class="artigo-badge-wrap">
        <span class="artigo-badge">{{ artigo.categoria }}</span>
      </div>

      <!-- Título -->
      <h1 class="artigo-titulo" itemprop="headline">{{ artigo.titulo }}</h1>

      <!-- Meta do artigo -->
      <div class="artigo-meta">
        <div class="artigo-meta-autor">
          <img src="/assets/img/autor-leonardo.jpg" alt="Leonardo Monteiro" class="artigo-meta-avatar" width="40" height="40" loading="lazy">
          <div>
            <span class="artigo-meta-nome" itemprop="author" itemscope itemtype="https://schema.org/Person">
              <span itemprop="name">Leonardo Monteiro</span>
            </span>
            <span class="artigo-meta-credencial">Jornalista · MTE 0041108/RJ</span>
          </div>
        </div>
        <div class="artigo-meta-info">
          <time class="artigo-meta-data" datetime="{{ artigo.publicado_em }}" itemprop="datePublished">
            {{ artigo.publicado_em_formatado }}
          </time>
          <span class="artigo-meta-sep" aria-hidden="true">·</span>
          <span class="artigo-meta-leitura">{{ artigo.tempo_leitura or '5' }} min de leitura</span>
        </div>

        <!-- Botões de compartilhamento -->
        <div class="artigo-share" aria-label="Compartilhar artigo">
          <span class="artigo-share-label">Compartilhar:</span>
          <a href="https://wa.me/?text={{ (artigo.titulo + ' — ' + 'https://brasilescolas.com.br/artigos/' + artigo.slug + '/')|urlencode }}"
             class="share-btn share-whatsapp" target="_blank" rel="noopener noreferrer"
             aria-label="Compartilhar no WhatsApp">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href="https://twitter.com/intent/tweet?text={{ artigo.titulo|urlencode }}&url={{ ('https://brasilescolas.com.br/artigos/' + artigo.slug + '/')|urlencode }}&via=brasilescolas"
             class="share-btn share-twitter" target="_blank" rel="noopener noreferrer"
             aria-label="Compartilhar no Twitter/X">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Twitter
          </a>
          <a href="https://www.linkedin.com/shareArticle?mini=true&url={{ ('https://brasilescolas.com.br/artigos/' + artigo.slug + '/')|urlencode }}&title={{ artigo.titulo|urlencode }}"
             class="share-btn share-linkedin" target="_blank" rel="noopener noreferrer"
             aria-label="Compartilhar no LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>
      </div>

      <!-- Imagem principal -->
      <figure class="artigo-imagem-principal" itemprop="image" itemscope itemtype="https://schema.org/ImageObject">
        <img src="{{ artigo.imagem_url }}" alt="{{ artigo.imagem_alt or artigo.titulo }}"
             class="artigo-imagem" width="800" height="450"
             loading="lazy" decoding="async"
             itemprop="url">
        {% if artigo.imagem_alt %}
        <figcaption class="artigo-imagem-caption" itemprop="caption">{{ artigo.imagem_alt }}</figcaption>
        {% endif %}
      </figure>

      <!-- Corpo do artigo -->
      <div class="artigo-body" id="artigo-body" itemprop="articleBody">
        {{ artigo.conteudo|safe }}
      </div>

      <!-- AdSense antes do fechamento -->
      <div class="adsense-block adsense-bottom" aria-label="Publicidade">
        <ins class="adsbygoogle"
             style="display:block"
             data-ad-client="ca-pub-6391161522269960"
             data-ad-slot="auto"
             data-ad-format="auto"
             data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>

      <!-- Bloco Amazon Afiliados -->
      <aside class="amazon-afiliados" aria-label="Recursos recomendados">
        <div class="amazon-afiliados-header">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          Recursos recomendados
        </div>
        <p class="amazon-afiliados-sub">Livros e materiais selecionados para pais e educadores</p>
        <div class="amazon-produtos" id="amazon-produtos">
          <!-- Produtos inseridos via JS ou pipeline -->
          <div class="amazon-produto-placeholder">
            <a href="https://www.amazon.com.br/s?k={{ artigo.categoria|urlencode }}&tag=brasilescolas-20"
               target="_blank" rel="noopener noreferrer sponsored"
               class="amazon-ver-todos">
              Ver livros sobre {{ artigo.categoria }} na Amazon
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </div>
        </div>
      </aside>

      <!-- Compartilhar novamente -->
      <div class="artigo-share artigo-share-bottom" aria-label="Compartilhar artigo">
        <span class="artigo-share-label">Gostou? Compartilhe:</span>
        <a href="https://wa.me/?text={{ (artigo.titulo + ' — ' + 'https://brasilescolas.com.br/artigos/' + artigo.slug + '/')|urlencode }}"
           class="share-btn share-whatsapp" target="_blank" rel="noopener noreferrer"
           aria-label="Compartilhar no WhatsApp">WhatsApp</a>
        <a href="https://twitter.com/intent/tweet?text={{ artigo.titulo|urlencode }}&url={{ ('https://brasilescolas.com.br/artigos/' + artigo.slug + '/')|urlencode }}"
           class="share-btn share-twitter" target="_blank" rel="noopener noreferrer"
           aria-label="Compartilhar no Twitter/X">Twitter</a>
        <a href="https://www.linkedin.com/shareArticle?mini=true&url={{ ('https://brasilescolas.com.br/artigos/' + artigo.slug + '/')|urlencode }}&title={{ artigo.titulo|urlencode }}"
           class="share-btn share-linkedin" target="_blank" rel="noopener noreferrer"
           aria-label="Compartilhar no LinkedIn">LinkedIn</a>
      </div>

    </div><!-- /.artigo-wrapper -->
  </article>

  <!-- Artigos relacionados -->
  <section class="artigos-relacionados" aria-labelledby="relacionadosTitle">
    <div class="container">
      <h2 class="section-title" id="relacionadosTitle">Artigos relacionados</h2>
      <div class="artigos-grid artigos-grid-3" id="relacionadosGrid" role="list" aria-label="Artigos relacionados">
        <!-- Carregado via JS do Supabase -->
        <div class="artigos-loading" aria-live="polite">
          <span class="spinner" aria-hidden="true"></span>
          <span class="sr-only">Carregando artigos relacionados…</span>
        </div>
      </div>
    </div>
  </section>

</main>

