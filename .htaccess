# Brasil Escolas — Site Estático
# Servir index.html antes de index.php (substituir WordPress)
DirectoryIndex index.html index.php

Options -Indexes
RewriteEngine On

# Redirecionar www para sem-www
RewriteCond %{HTTP_HOST} ^www\.brasilescolas\.com\.br [NC]
RewriteRule ^ https://brasilescolas.com.br%{REQUEST_URI} [R=301,L]

# ── CLIENT-SIDE ROUTING ──────────────────────────────────────
# Estas regras vêm ANTES do bloco "arquivo/dir existe" para que
# slugs com diretórios físicos legados (WordPress) sejam interceptados.

# Web Stories: rotas individuais servidas via arquivos físicos em web-stories/{slug}/index.html
# (não usa mod_rewrite — o Apache serve o DirectoryIndex diretamente)

# Escolas: /escolas/{slug}/ (sem UF) → index.html
RewriteRule ^escolas/([a-z0-9][a-z0-9-]+)/?$ /escolas/index.html [L]

# Escolas: /escolas/{uf}/{slug}/ (com UF de 2 letras) → index.html
RewriteRule ^escolas/([a-z]{2})/([^/]+)/?$ /escolas/index.html [L]

# ─────────────────────────────────────────────────────────────

# Se o arquivo ou diretório físico existir, servir diretamente
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Rotas sem extensão: tentar .html
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]

# Tipos MIME corretos
AddType application/manifest+json .webmanifest
AddType text/plain .txt

# Cache estático (1 ano para assets imutáveis)
<FilesMatch "\.(css|js|woff2|png|jpg|svg|ico)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

<FilesMatch "\.(html|htm)$">
  Header set Cache-Control "public, max-age=3600"
</FilesMatch>
